{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/functions/collectLatestNews",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/functions/updateMarketSnapshots",
      "schedule": "*/15 * * * *"
    }
  ]
}
