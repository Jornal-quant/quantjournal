# Runtime backend selector
# Keep "base44" while the app is still published through Base44.
# Use "neon" on Vercel after DATABASE_URL is configured.
VITE_DATA_BACKEND=base44

# Base44 runtime, only needed while VITE_DATA_BACKEND=base44
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# Neon/Vercel runtime, server-side only. Never expose this in VITE_* vars.
DATABASE_URL=

# AI provider for Vercel API routes
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHEAP_MODEL=deepseek-chat
DEEPSEEK_QUALITY_MODEL=deepseek-reasoner

# Optional email provider for newsletter API routes
RESEND_API_KEY=
NEWSLETTER_FROM=FinAI Pulse <news@your-domain.com>
