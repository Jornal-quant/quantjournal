# Runtime backend selector
# Keep "base44" while the app is still published through Base44.
# Use "neon" on Vercel after DATABASE_URL is configured.
VITE_DATA_BACKEND=base44

# Base44 runtime, only needed while VITE_DATA_BACKEND=base44
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# Neon/Vercel runtime, server-side only. Never expose this in VITE_* vars.
DATABASE_URL=

# AI provider for Vercel API routes
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHEAP_MODEL=deepseek-chat
DEEPSEEK_QUALITY_MODEL=deepseek-reasoner

# Optional email provider for newsletter API routes
RESEND_API_KEY=
NEWSLETTER_FROM=FinAI Pulse <news@your-domain.com>

# Optional market-news APIs. The matching collector in collectLatestNews only
# runs when its key is set; without keys the RSS sources still work normally.
# Finnhub (mundo): https://finnhub.io/  | free 60 req/min
FINNHUB_API_KEY=
# GNews (Brasil, country=br): https://gnews.io/  | free 100 req/dia
GNEWS_API_KEY=

# Máx. de artigos gerados por IA a cada coleta (controla custo do DeepSeek). Padrão: 3
AUTO_PROCESS_LIMIT=3

# Cotações globais (forex, cripto, índices, commodities) via Twelve Data.
# Opcional — sem a key, updateMarketSnapshots usa as fontes grátis atuais
# (Yahoo/AwesomeAPI/CoinGecko/BCB). Com a key, a TD tem precedência.
# https://twelvedata.com/  | free 800 req/dia, 8 req/min
TWELVEDATA_API_KEY=
